API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

ESMFOLD_API_URL=https://api.esmatlas.com/foldSequence/v1/pdb/
ESMFOLD_TIMEOUT=300
ESMFOLD_RETRIES=3

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=propredict

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

PLDDT_ACCEPT_THRESHOLD=75.0
PLDDT_REFINE_THRESHOLD=60.0

JOB_TIMEOUT_SECONDS=600
ENSEMBLE_NUM_SEEDS=1

# Tool feature flags — set True only after installing the tool
# PyRosetta: conda install -c rosettacommons pyrosetta
ROSETTA_ENABLED=False
# GROMACS: brew install gromacs  (M3 Mac)
GROMACS_ENABLED=False
GROMACS_BIN=gmx
# OpenMM: conda install -c conda-forge openmm
OPENMM_ENABLED=False
# RoseTTAFold2: see github.com/baker-lab/RoseTTAFold2
ROSETTAFOLD_ENABLED=False
# OpenFold: pip install 'openfold @ git+https://github.com/aqlaboratory/openfold'
OPENFOLD_ENABLED=False

# MD simulation
MD_PRODUCTION_NS=0.1

# Stage F — Membrane & Ligand environments
# insane.py: download from http://cgmartini.nl and set path, OR place on PATH
INSANE_PATH=
# GROMACS force field name for membrane runs (charmm36m-ildn requires CHARMM36m installed)
# charmm36-feb2026 is installed by Dockerfile.celery from the MacKerell lab
MEMBRANE_FF=charmm36-feb2026_cgenff-5.0
# GNINA docking binary (https://github.com/gnina/gnina/releases)
GNINA_BIN=gnina

# Agentic refinement loop (Stage D)
# Requires: pip install anthropic
AGENT_ENABLED=False
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-6
AGENT_MAX_ITERATIONS=5

# Cache
CACHE_TTL=86400

LOG_LEVEL=INFO
