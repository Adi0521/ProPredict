API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# ESMFold: use local model (True) or remote API (False)
ESMFOLD_LOCAL=True
ESMFOLD_MODEL_NAME=facebook/esmfold_v1
# Remote API fallback (only used when ESMFOLD_LOCAL=False)
ESMFOLD_API_URL=https://api.esmatlas.com/foldSequence/v1/pdb/
ESMFOLD_TIMEOUT=300
ESMFOLD_RETRIES=3

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=propredict

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

PLDDT_ACCEPT_THRESHOLD=75.0
PLDDT_REFINE_THRESHOLD=60.0

# MD simulation validation: escalate when a trajectory looks unphysical
SIM_RMSD_MAX_NM=2.0
SIM_RG_DIVERGENCE_FACTOR=3.0

JOB_TIMEOUT_SECONDS=600
ENSEMBLE_NUM_SEEDS=1

# Iterative refinement: re-predict with new seeds / relax until accept or budget exhausted
REFINEMENT_MAX_ITERATIONS=10
# Stop early if pLDDT improves by less than this per iteration
REFINEMENT_PLDDT_PLATEAU_DELTA=0.5

# Tool feature flags — set True only after installing the tool
# PyRosetta: conda install -c rosettacommons pyrosetta
ROSETTA_ENABLED=False
# GROMACS: brew install gromacs  (M3 Mac)
GROMACS_ENABLED=False
GROMACS_BIN=gmx
# OpenMM: conda install -c conda-forge openmm
OPENMM_ENABLED=False
# RoseTTAFold2: see github.com/baker-lab/RoseTTAFold2
ROSETTAFOLD_ENABLED=False
# OpenFold: pip install 'openfold @ git+https://github.com/aqlaboratory/openfold'
OPENFOLD_ENABLED=False
# Boltz-2: pip install git+https://github.com/jwohlwend/boltz (GPU required)
BOLTZ_ENABLED=False
BOLTZ_DIFFUSION_SAMPLES=1
BOLTZ_SAMPLING_STEPS=200
# False = fully local (no network); True = use ColabFold MSA server (better accuracy)
BOLTZ_USE_MSA=False
BOLTZ_MSA_SERVER_URL=https://api.colabfold.com

# MD simulation
MD_PRODUCTION_NS=0.1

# Stage F — Membrane & Ligand environments
# insane.py: download from http://cgmartini.nl and set path, OR place on PATH
INSANE_PATH=
# GROMACS force field name for membrane runs (charmm36m-ildn requires CHARMM36m installed)
# charmm36-feb2026 is installed by Dockerfile.celery from the MacKerell lab
MEMBRANE_FF=charmm36-feb2026_cgenff-5.0
# GNINA docking binary (https://github.com/gnina/gnina/releases)
GNINA_BIN=gnina

# Path to a local clone of https://github.com/dauparas/ProteinMPNN (MIT license).
# Model weights are included in the clone itself (~26MB) — no separate download.
#   git clone https://github.com/dauparas/ProteinMPNN.git
# Powers the agent's scan_mutations tool (orchestrator/mutation_scan.py). Leave blank to
# disable it (the tool then reports "unavailable" and the agent falls back gracefully).
# In Docker/Modal the clone is baked into the image at /opt/ProteinMPNN — for Docker set
# this to /opt/ProteinMPNN (config loads .env with override=True, so a blank/host value
# here would otherwise win inside the container).
PROTEINMPNN_PATH=
PROTEINMPNN_MODEL_NAME=v_48_020
# ProteinMPNN scoring reproducibility. SEED MUST BE NON-ZERO — ProteinMPNN treats
# seed=0 as "unset" and randomizes, making scores non-reproducible.
PROTEINMPNN_SEED=37
# Number of random decoding orders averaged per scan. Higher = less noise, linearly
# more compute. 8 is a reasonable default; 1 reproduces the old single-sample behavior.
PROTEINMPNN_NUM_DECODING_ORDERS=8

# Agentic refinement loop (Stage D)
# Requires: pip install anthropic
AGENT_ENABLED=False
AGENT_API_KEY=<your-deepseek-api-key>
AGENT_BASE_URL=https://api.deepseek.com/anthropic
AGENT_MODEL=deepseek-v4-flash
AGENT_MAX_ITERATIONS=5
# Max apply_mutation calls per agent session, independent of AGENT_MAX_ITERATIONS.
AGENT_MAX_MUTATIONS=3

# Weights & Biases (optional benchmark tracking)
# pip install wandb && wandb login
WANDB_API_KEY=
WANDB_PROJECT=
WANDB_ENTITY=

# Cache
CACHE_TTL=86400

LOG_LEVEL=INFO
